%% Backend Dependencies — @clitoris/server
%% Shows how server modules depend on each other and external packages

graph TD
    subgraph "@clitoris/server"
        INDEX["index.ts<br/>(entry point)"]
        APP["app.ts<br/>(Express setup)"]

        subgraph Routes
            POSTS_R["routes/posts.ts"]
            USERS_R["routes/users.ts"]
            LLM_R["routes/llm.ts"]
            AUTH_R["routes/auth.ts"]
        end

        subgraph Middleware
            AUTH_M["middleware/auth.ts"]
            VALIDATE_M["middleware/validate.ts"]
            RATE_M["middleware/rate-limit.ts"]
            ERROR_M["middleware/error.ts"]
        end

        subgraph Database
            DB["db/index.ts<br/>(connection + migrations)"]
            SCHEMA["db/schema.ts<br/>(queries)"]
            MIGRATIONS["db/migrations/<br/>001_create_users.sql<br/>002_create_posts.sql<br/>003_create_social.sql"]
        end
    end

    subgraph "@clitoris/shared"
        TYPES["types/<br/>user.ts, post.ts, api.ts"]
        CONSTANTS["constants/<br/>models.ts, limits.ts"]
    end

    subgraph "@clitoris/llm"
        LLM_INDEX["index.ts<br/>(provider factory)"]
        ANTHROPIC["providers/anthropic.ts"]
        OPENAI["providers/openai.ts"]
        OLLAMA["providers/ollama.ts"]
        TRANSFORMER["transformer.ts"]
    end

    subgraph "External Packages"
        EXPRESS["express"]
        BETTER_SQLITE["better-sqlite3"]
        PINO["pino"]
        ZOD["zod"]
        SESSION["express-session"]
        RATE_LIMIT["express-rate-limit"]
        ANTHROPIC_SDK["@anthropic-ai/sdk"]
        OPENAI_SDK["openai"]
    end

    %% Server internal flow
    INDEX --> APP
    APP --> POSTS_R
    APP --> USERS_R
    APP --> LLM_R
    APP --> AUTH_R
    APP --> AUTH_M
    APP --> ERROR_M

    %% Routes use middleware
    POSTS_R --> AUTH_M
    POSTS_R --> VALIDATE_M
    USERS_R --> AUTH_M
    LLM_R --> AUTH_M
    LLM_R --> VALIDATE_M
    LLM_R --> RATE_M
    AUTH_R --> VALIDATE_M

    %% Routes use DB
    POSTS_R --> SCHEMA
    USERS_R --> SCHEMA
    AUTH_R --> SCHEMA
    SCHEMA --> DB
    DB --> MIGRATIONS

    %% Routes use LLM
    LLM_R --> LLM_INDEX
    LLM_INDEX --> ANTHROPIC
    LLM_INDEX --> OPENAI
    LLM_INDEX --> OLLAMA
    LLM_INDEX --> TRANSFORMER

    %% Shared types
    POSTS_R --> TYPES
    USERS_R --> TYPES
    LLM_R --> TYPES
    SCHEMA --> TYPES
    LLM_INDEX --> TYPES
    VALIDATE_M --> CONSTANTS

    %% External dependencies
    APP --> EXPRESS
    DB --> BETTER_SQLITE
    INDEX --> PINO
    VALIDATE_M --> ZOD
    AUTH_M --> SESSION
    RATE_M --> RATE_LIMIT
    ANTHROPIC --> ANTHROPIC_SDK
    OPENAI --> OPENAI_SDK

    %% Styling
    classDef server fill:#0f3460,stroke:#4ade80,color:#e2e8f0
    classDef shared fill:#16213e,stroke:#a78bfa,color:#e2e8f0
    classDef llm fill:#16213e,stroke:#22d3ee,color:#e2e8f0
    classDef external fill:#1a1a2e,stroke:#64748b,color:#94a3b8

    class INDEX,APP,POSTS_R,USERS_R,LLM_R,AUTH_R,AUTH_M,VALIDATE_M,RATE_M,ERROR_M,DB,SCHEMA,MIGRATIONS server
    class TYPES,CONSTANTS shared
    class LLM_INDEX,ANTHROPIC,OPENAI,OLLAMA,TRANSFORMER llm
    class EXPRESS,BETTER_SQLITE,PINO,ZOD,SESSION,RATE_LIMIT,ANTHROPIC_SDK,OPENAI_SDK external
