# Server
PORT=3771
GITHUB_REDIRECT_URI=http://localhost:3771/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
CLIENT_URL=http://localhost:7878
NODE_ENV=development
DATABASE_URL=forkverse.db
SESSION_SECRET=replace-with-random-string-at-least-32-chars
ENCRYPTION_KEY=generate-64-char-hex-string-for-aes256-key-encryption
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:7878

# LLM API keys are NOT stored here.
# Users enter their own API keys in Settings (/settings).
# Keys are stored per-user in the database (user_llm_keys table).
# Only Ollama (local) and CLI tools (claude, codex) work without a key.

# Optional: Cursor local API base (CLI status model list + /llm/transform when using Cursor)
# CURSOR_LLM_BASE=http://localhost:3100/v1

# Client (prefix with VITE_)
VITE_API_URL=/api
